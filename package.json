{
  "name": "mdkk-ui",
  "version": "0.1.0",
  "description": "React component library built on top of react-aria-components",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./aspect-ratio": {
      "types": "./dist/components/AspectRatio/AspectRatio.d.ts",
      "import": "./dist/components/AspectRatio/AspectRatio.js"
    },
    "./badge": {
      "types": "./dist/components/Badge/Badge.d.ts",
      "import": "./dist/components/Badge/Badge.js"
    },
    "./button": {
      "types": "./dist/components/Button/Button.d.ts",
      "import": "./dist/components/Button/Button.js"
    },
    "./card": {
      "types": "./dist/components/Card/Card.d.ts",
      "import": "./dist/components/Card/Card.js"
    },
    "./checkbox": {
      "types": "./dist/components/Checkbox/Checkbox.d.ts",
      "import": "./dist/components/Checkbox/Checkbox.js"
    },
    "./checkbox-group": {
      "types": "./dist/components/Checkbox/CheckboxGroup.d.ts",
      "import": "./dist/components/Checkbox/CheckboxGroup.js"
    },
    "./combobox": {
      "types": "./dist/components/Combobox/Combobox.d.ts",
      "import": "./dist/components/Combobox/Combobox.js"
    },
    "./dialog": {
      "types": "./dist/components/Dialog/Dialog.d.ts",
      "import": "./dist/components/Dialog/Dialog.js"
    },
    "./drawer": {
      "types": "./dist/components/Drawer/Drawer.d.ts",
      "import": "./dist/components/Drawer/Drawer.js"
    },
    "./dropdown-menu": {
      "types": "./dist/components/DropdownMenu/DropdownMenu.d.ts",
      "import": "./dist/components/DropdownMenu/DropdownMenu.js"
    },
    "./field-error": {
      "types": "./dist/components/FieldError/FieldError.d.ts",
      "import": "./dist/components/FieldError/FieldError.js"
    },
    "./input": {
      "types": "./dist/components/Input/Input.d.ts",
      "import": "./dist/components/Input/Input.js"
    },
    "./label": {
      "types": "./dist/components/Label/Label.d.ts",
      "import": "./dist/components/Label/Label.js"
    },
    "./progress-circle": {
      "types": "./dist/components/ProgressCircle/ProgressCircle.d.ts",
      "import": "./dist/components/ProgressCircle/ProgressCircle.js"
    },
    "./select": {
      "types": "./dist/components/Select/Select.d.ts",
      "import": "./dist/components/Select/Select.js"
    },
    "./sidebar": {
      "types": "./dist/components/Sidebar/index.d.ts",
      "import": "./dist/components/Sidebar/index.js"
    },
    "./skeleton": {
      "types": "./dist/components/Skeleton/Skeleton.d.ts",
      "import": "./dist/components/Skeleton/Skeleton.js"
    },
    "./story": {
      "types": "./dist/components/Story/Story.d.ts",
      "import": "./dist/components/Story/Story.js"
    },
    "./story-list": {
      "types": "./dist/components/Story/StoryList.d.ts",
      "import": "./dist/components/Story/StoryList.js"
    },
    "./story-list-item": {
      "types": "./dist/components/Story/StoryListItem.d.ts",
      "import": "./dist/components/Story/StoryListItem.js"
    },
    "./tabs": {
      "types": "./dist/components/Tabs/Tabs.d.ts",
      "import": "./dist/components/Tabs/Tabs.js"
    },
    "./text": {
      "types": "./dist/components/Text/Text.d.ts",
      "import": "./dist/components/Text/Text.js"
    },
    "./text-area": {
      "types": "./dist/components/TextArea/TextArea.d.ts",
      "import": "./dist/components/TextArea/TextArea.js"
    },
    "./text-field": {
      "types": "./dist/components/TextField/TextField.d.ts",
      "import": "./dist/components/TextField/TextField.js"
    },
    "./toast": {
      "types": "./dist/components/Toast/Toast.d.ts",
      "import": "./dist/components/Toast/Toast.js"
    },
    "./tooltip": {
      "types": "./dist/components/Tooltip/Tooltip.d.ts",
      "import": "./dist/components/Tooltip/Tooltip.js"
    },
    "./tailwind-plugin": {
      "types": "./dist/tailwind-plugin.d.ts",
      "import": "./dist/tailwind-plugin.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "scripts": {
    "dev": "vite",
    "generate:icons": "node --experimental-transform-types ./scripts/generate-icons.ts && pnpm exec biome format --write ./src/components/Icons/generated",
    "prebuild": "pnpm run generate:icons",
    "build": "vite build",
    "hooks:install": "lefthook install",
    "prepack": "pnpm run check && pnpm run typecheck && pnpm run build",
    "preview": "vite preview",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write --unsafe .",
    "check:icons": "node --experimental-transform-types ./scripts/verify-lucide-icons.ts",
    "check": "pnpm -s check:icons && biome check",
    "check:fix": "biome lint --write --unsafe . && biome format --write .",
    "typecheck": "tsc --noEmit",
    "generate:figma-types": "openapi-typescript ./node_modules/@figma/rest-api-spec/openapi/openapi.yaml -o ./src/ui/libs/open-api/figma-api.d.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest --project=unit",
    "test:unit": "vitest --project=unit",
    "test-storybook": "vitest --project=storybook"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "cva": "1.0.0-beta.4",
    "react-aria-components": "^1.14.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^9.39.1",
    "@hookform/resolvers": "^5.2.2",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@storybook/test": "^8.6.15",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "chromatic": "^16.3.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.1.11",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.11",
    "jp-zipcode-lookup": "^0.3.5",
    "jsdom": "^27.0.1",
    "lefthook": "^2.1.6",
    "lucide-static": "^1.8.0",
    "playwright": "^1.57.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "storybook": "^10.1.11",
    "tailwindcss": "^4.2.2",
    "tailwindcss-react-aria-components": "^2.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.16",
    "zod": "^4.3.6"
  }
}
